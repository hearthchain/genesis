{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "none",
    "strict": true,
    "useUnknownInCatchVariables": false,
    "noEmitOnError": true,
    "removeComments": false,
    "newLine": "lf",
    "rootDir": ".",
    "outDir": "../web/assets/js",
    "types": [],
    "noUnusedLocals": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["*.ts"]
}
